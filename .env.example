# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         SECURE LINK — Environment Variables                ║
# ║                                                                            ║
# ║  Copy this file to .env and fill in your values.                           ║
# ║  Works identically on Replit, Vercel, local development, or any host.      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ── DATABASE (Required) ──────────────────────────────────────────────────────
# PostgreSQL connection string.
#   - Replit: Provided automatically by Replit's built-in PostgreSQL database.
#   - Vercel: Use Vercel Postgres, Neon, Supabase, or any hosted PostgreSQL.
#   - Local:  Install PostgreSQL locally or use a free cloud instance.
DATABASE_URL="postgresql://user:password@localhost:5432/securelink?sslmode=require"


# ── AUTHENTICATION (Required) ────────────────────────────────────────────────
# Base URL of your application. Must match where your app is actually running.
#   - Local:  http://localhost:5000
#   - Replit: Your Repl's public URL (e.g., https://your-repl.replit.app)
#   - Vercel: Your production domain (e.g., https://securelink.yourdomain.com)
NEXTAUTH_URL="http://localhost:5000"

# Secret key for signing session tokens. Must be the same across deployments.
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-a-random-64-char-hex-string"


# ── ENCRYPTION (Required) ────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM field-level encryption (64 hex characters).
# IMPORTANT: Once set, do NOT change this key or all existing encrypted data
# becomes unreadable. Use the same key across all environments.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-hex-chars"


# ── EMAIL — Resend (Recommended) ─────────────────────────────────────────────
# Sends secure links to clients, password reset emails, and submission
# notifications to agents. If not configured, email features are silently
# disabled — the app still works without it.
#
# Sign up:  https://resend.com
# Get key:  https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
#
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Secure Link <noreply@yourdomain.com>"


# ── SMS — Twilio (Recommended) ───────────────────────────────────────────────
# Sends secure links to clients via text message.
# If not configured, the SMS button is hidden from the dashboard.
#
# Sign up:        https://www.twilio.com/try-twilio
# Get credentials: https://console.twilio.com
#                  (Account SID and Auth Token are on the main dashboard)
# Buy a number:   https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
# Free trial:     Includes ~$15 credit for testing
#
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15550000000"


# ── RATE LIMITING — Upstash Redis (Optional) ─────────────────────────────────
# Distributed rate limiting for submission and auth endpoints.
# If not configured, uses an in-memory fallback (works fine for single-server).
# Recommended for production with multiple server instances.
#
# Sign up:    https://console.upstash.com
# Create DB:  Choose "Global" region for best latency
# Get values: Database details page > REST API section
# Free tier:  10,000 commands/day
#
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ── CRON CLEANUP (Optional) ──────────────────────────────────────────────────
# Protects the /api/cron/cleanup endpoint that auto-deletes expired data.
# Set to any random string. Call the endpoint with ?secret=<value> or
# the Authorization: Bearer <value> header.
# Generate: openssl rand -hex 16
CRON_SECRET=""


# ── PRIVACY (Optional) ───────────────────────────────────────────────────────
# Set to "true" to store client IP addresses in audit logs.
# Default is "false" for maximum privacy.
AUDIT_STORE_IP="false"
