# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (default for development)
DATABASE_URL="file:./dev.db"

# Production: switch to Postgres
# DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM field encryption, hex-encoded (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-hex-chars"

# ── Privacy: Audit logs ───────────────────────────────────────────────────────
# Set to "true" to store IP addresses in audit logs (off by default)
AUDIT_STORE_IP="false"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. If not set, email notifications are silently skipped.
# Get your key at https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Secure Links <noreply@yourdomain.com>"

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Optional. If not set, the SMS button is hidden from the dashboard.
# Get your credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15550000000"

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Optional. If unset, local in-memory fallback is used.
# Get values from Upstash Redis REST API settings.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cron cleanup job ──────────────────────────────────────────────────────────
# Optional but recommended for production. Protects /api/cron/cleanup.
# Set any random string. Pass as ?secret=<value> or Authorization: Bearer <value>
CRON_SECRET=""
