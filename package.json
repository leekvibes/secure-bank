{
  "name": "agent-secure-links",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs'); try{fs.rmSync('.next',{recursive:true,force:true})}catch{}\"",
    "postinstall": "prisma generate",
    "predev": "npm run clean:next",
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "prebuild": "npm run clean:next",
    "build": "next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
