    "nanoid": "^3.3.7",
    "next": "14.2.29",
    "next-auth": "^4.24.11",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.3",
