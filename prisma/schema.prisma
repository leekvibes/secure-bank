generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  displayName       String
  agencyName        String?
  company           String?
  phone             String?
  licenseNumber     String?
  licensedStates    String?  // comma-separated
  agentSlug         String   @unique
  // Branding
  logoUrl           String?  // base64 data URI
  photoUrl          String?  // base64 data URI for agent profile photo
  // Onboarding / context
  industry          String?
  destinationLabel  String?  // e.g. "EverQuote", "Carrier Application"
  carriersList      String?  // comma-separated display-only labels
  notificationEmail String?  // override email for submission alerts
  // Compliance / trust
  verificationStatus String  @default("UNVERIFIED") // UNVERIFIED | LICENSED | CERTIFIED | REGULATED
  dataRetentionDays  Int     @default(30)            // 30 | 60 | 90 | -1 (manual)
  trustMessage       String?
  defaultExpirationHours Int @default(24)
  // Billing
  plan                 String  @default("FREE")  // FREE | BEGINNER | PRO | AGENCY
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planOverride         String?   // admin manual override: FREE | BEGINNER | PRO | AGENCY
  planOverrideNote     String?
  planOverrideBy       String?
  planOverriddenAt     DateTime?
  // Profile change rate limiting (once per week)
  nameChangedAt        DateTime?
  photoChangedAt       DateTime?
  // Onboarding
  onboardingCompleted Boolean @default(false)
  role               String    @default("AGENT") // AGENT | ADMIN
  bannedAt           DateTime?
  banReason          String?
  emailVerified       Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  links                  SecureLink[]
  linkTemplates          LinkTemplate[]
  auditLogs              AuditLog[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  idUploads              IdUpload[]
  forms                  Form[]
  assets                 AgentAsset[]
  fileTransfers          FileTransfer[]
  feedback               Feedback[]
  docSignRequests        DocSignRequest[]
  templateUsages         TemplateUsage[]
}

model SecureLink {
  id            String     @id @default(cuid())
  token         String     @unique
  // BANKING_INFO | SSN_ONLY | FULL_INTAKE | ID_UPLOAD
  linkType      String
  destination   String?
  destinationLabel String?
  messageTemplate String?
  optionsJson   String?
  openedAt      DateTime?
  submittedAt   DateTime?
  clientName    String?
  clientPhone   String?
  clientEmail   String?
  expiresAt     DateTime
  retentionDays Int        @default(7)
  status        String     @default("CREATED") // CREATED | OPENED | SUBMITTED | EXPIRED
  reminderSentAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  agentId   String
  agent     User       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  submission Submission?
  idUpload   IdUpload?
  assets     SecureLinkAsset[]
  sends      LinkDispatch[]
  auditLogs  AuditLog[]
}

model Submission {
  id            String     @id @default(cuid())
  // All fields stored as ciphertext: base64(iv):base64(authTag):base64(ciphertext)
  encryptedData String
  revealedAt    DateTime?
  revealCount   Int        @default(0)
  deleteAt      DateTime
  createdAt     DateTime   @default(now())

  linkId String     @unique
  link   SecureLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model IdUpload {
  id             String     @id @default(cuid())
  // Paths to AES-256-GCM encrypted files on disk
  frontFilePath  String
  frontOriginalName String?
  frontMimeType  String?
  backFilePath   String?
  backOriginalName String?
  backMimeType   String?
  viewedAt       DateTime?
  viewCount      Int        @default(0)
  deleteAt       DateTime
  createdAt      DateTime   @default(now())

  linkId  String     @unique
  link    SecureLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  agentId String
  agent   User       @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Custom Form Builder ───────────────────────────────────────────────────────

model Form {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("ACTIVE") // ACTIVE | ARCHIVED
  retentionDays Int      @default(30)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentId     String
  agent       User     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  fields      FormField[]
  links       FormLink[]
  submissions FormSubmission[]
}

model FormField {
  id              String   @id @default(cuid())
  formId          String
  label           String
  fieldType       String   // text|email|phone|address|date|dropdown|ssn|routing|bank_account|signature
  placeholder     String?
  helpText        String?
  required        Boolean  @default(false)
  encrypted       Boolean  @default(true)
  maskInput       Boolean  @default(false)
  confirmField    Boolean  @default(false)
  dropdownOptions String?  // JSON: ["Option A","Option B"]
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  form   Form                  @relation(fields: [formId], references: [id], onDelete: Cascade)
  values FormSubmissionValue[]
}

model FormLink {
  id          String   @id @default(cuid())
  formId      String
  token       String   @unique
  destination String?
  destinationLabel String?
  messageTemplate String?
  optionsJson String?
  openedAt    DateTime?
  submittedAt DateTime?
  clientName  String?
  clientPhone String?
  clientEmail String?
  expiresAt   DateTime
  status      String   @default("CREATED") // CREATED | OPENED | SUBMITTED | EXPIRED
  createdAt   DateTime @default(now())

  form       Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  submission FormSubmission?
  assets     FormLinkAsset[]
  sends      FormLinkDispatch[]
}

model LinkDispatch {
  id        String   @id @default(cuid())
  linkId    String
  method    String   // SMS | EMAIL | COPY
  recipient String
  message   String
  createdAt DateTime @default(now())

  link SecureLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
}

model FormLinkDispatch {
  id         String   @id @default(cuid())
  formLinkId String
  method     String   // SMS | EMAIL | COPY | SHARE
  recipient  String
  message    String
  createdAt  DateTime @default(now())

  formLink FormLink @relation(fields: [formLinkId], references: [id], onDelete: Cascade)

  @@index([formLinkId, createdAt])
}

model LinkTemplate {
  id              String   @id @default(cuid())
  userId          String
  name            String
  linkType        String
  destinationLabel String?
  expiresIn       Int      @default(24)
  messageTemplate String?
  optionsJson     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets LinkTemplateAsset[]
}

model LinkTemplateAsset {
  id         String   @id @default(cuid())
  templateId String
  assetId    String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  template LinkTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  asset    AgentAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([templateId, assetId])
  @@index([templateId, order])
}

model FormSubmission {
  id         String    @id @default(cuid())
  formLinkId String    @unique
  formId     String
  deleteAt   DateTime
  viewedAt   DateTime?
  createdAt  DateTime  @default(now())

  formLink FormLink              @relation(fields: [formLinkId], references: [id], onDelete: Cascade)
  form     Form                  @relation(fields: [formId], references: [id])
  values   FormSubmissionValue[]
}

model FormSubmissionValue {
  id           String   @id @default(cuid())
  submissionId String
  fieldId      String
  fieldLabel   String
  value        String
  isEncrypted  Boolean  @default(false)

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field      FormField      @relation(fields: [fieldId], references: [id])
}

model AgentAsset {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("LOGO") // LOGO | AVATAR | BANNER
  name      String?
  fileKey   String?
  url       String?
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  secureLinkRefs  SecureLinkAsset[]
  formLinkRefs    FormLinkAsset[]
  templateRefs    LinkTemplateAsset[]
}

model SecureLinkAsset {
  id           String   @id @default(cuid())
  secureLinkId String
  assetId      String
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  secureLink SecureLink @relation(fields: [secureLinkId], references: [id], onDelete: Cascade)
  asset      AgentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([secureLinkId, assetId])
  @@index([secureLinkId, order])
}

model FormLinkAsset {
  id         String   @id @default(cuid())
  formLinkId String
  assetId    String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  formLink FormLink   @relation(fields: [formLinkId], references: [id], onDelete: Cascade)
  asset    AgentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([formLinkId, assetId])
  @@index([formLinkId, order])
}

// ─────────────────────────────────────────────────────────────────────────────

model FileTransfer {
  id               String   @id @default(cuid())
  token            String   @unique
  title            String?
  message          String?
  viewOnce         Boolean  @default(false)
  expiresAt        DateTime
  status           String   @default("ACTIVE") // ACTIVE | EXPIRED | DOWNLOADED
  notifyOnDownload Boolean  @default(true)
  totalSizeBytes   BigInt   @default(0)
  createdAt        DateTime @default(now())

  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  files FileTransferFile[]
}

model FileTransferFile {
  id            String   @id @default(cuid())
  transferId    String
  fileName      String
  mimeType      String
  sizeBytes     BigInt
  blobUrl       String
  downloadCount Int      @default(0)
  previewCount  Int      @default(0)
  createdAt     DateTime @default(now())

  transfer FileTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  event     String
  ipAddress String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())

  agentId String?
  agent   User?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  linkId  String?
  link    SecureLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  category  String   // BUG | FEATURE | UX | OTHER
  message   String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// Document Signing

model DocSignRequest {
  id            String   @id @default(cuid())
  token         String   @unique
  title         String?
  message       String?
  status        String   @default("DRAFT") // DRAFT | SENT | OPENED | COMPLETED | EXPIRED
  // Encrypted storage paths for original and final signed PDF
  originalFilePath String
  signedFilePath   String?
  originalName     String?
  // Field placement data as JSON array
  fieldsJson    String?
  // Agent pre-sign data as JSON
  agentSignJson String?
  clientName    String?
  clientEmail   String?
  expiresAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  auditLogs DocSignAuditLog[]
}

model DocSignAuditLog {
  id        String   @id @default(cuid())
  event     String   // CREATED | SENT | OPENED | SIGNED | COMPLETED
  metadata  String?
  createdAt DateTime @default(now())

  requestId String
  request   DocSignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// System Templates

model SystemTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   // Insurance | Banking | Compliance | Mortgage | General
  industry    String?  // INSURANCE | MORTGAGE | BANKING | GENERAL
  type        String   // SECURE_LINK | FORM
  // For SECURE_LINK templates
  linkType    String?
  optionsJson String?
  // For FORM templates — JSON array of field definitions
  fieldsJson  String?
  tags        String?  // comma-separated
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usages TemplateUsage[]
}

model TemplateUsage {
  id         String   @id @default(cuid())
  templateId String
  agentId    String
  createdAt  DateTime @default(now())

  template SystemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  agent    User           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Mission Control Admin Audit Log

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  adminEmail  String
  action      String   // PLAN_OVERRIDE | BAN_USER | UNBAN_USER | VERIFY_EMAIL | RESET_PASSWORD | CLEAR_OVERRIDE
  targetId    String
  targetEmail String?
  oldValue    String?
  newValue    String?
  note        String?
  ip          String?
  createdAt   DateTime @default(now())
}
